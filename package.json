{
  "name": "@geikha/datamoshlive",
  "version": "0.1.1",
  "type": "module",
  "description": "Real-time datamosh effects in the browser using WebCodecs",
  "main": "dist/datamoshlive.js",
  "module": "dist/datamoshlive.esm.js",
  "exports": {
    ".": {
      "import": "./dist/datamoshlive.esm.js",
      "default": "./dist/datamoshlive.js"
    }
  },
  "files": ["dist"],
  "repository": {
